{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "updater:default",
    "process:allow-restart",
    "fs:default",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$APP/**" }, { "path": "$DOWNLOAD/**" }]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "$APP/**" }, { "path": "$DOWNLOAD/**" }]
    },
    "dialog:default",
    "dialog:allow-save"
  ]
}
