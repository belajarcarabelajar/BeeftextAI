{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BeefText AI",
  "version": "0.2.9",
  "identifier": "com.tedi-rahmat.beeftextai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BeefText AI — Smart Text Expander",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },

  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZFNzVBNzY2NkJBQjBFM0QKUldROURxdHJacWQxL25NQXV5MC94ZnF2Wmc5WGJoSWlNc0d4dDZXVTJ4RmpNUSt0QWRLVUNIOWcK",
      "endpoints": [
        "https://github.com/belajarcarabelajar/BeeftextAI/releases/latest/download/latest.json"
      ]
    },
    "process": {},
    "fs": {
      "scope": ["**"]
    }
  }
}
